# CMake
build/
build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CMakeUserPresets.json
*.cmake
!CMakeLists.txt
!*.cmake.in

# Python 打包与构建
dist/
*.egg-info/
.eggs/
*.manifest
*.spec

# --------------------- 可执行文件（特定项目） ------------
synthpp
synthpp.exe

# --------------------- 依赖管理 --------------------------
# vcpkg / Conan
vcpkg_installed/
conaninfo.txt
conanbuildinfo.*
conan.lock

# Python 依赖与虚拟环境
pip-log.txt
pip-delete-this-directory.txt
.env                           # 环境变量文件（也归入用户配置）
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

